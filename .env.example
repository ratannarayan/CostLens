# ============================================================
# CostLens — Environment Variables
# Copy to .env and fill in actual values
# ============================================================

# ─── APP ───
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
APP_SECRET=generate-a-64-char-random-string-here

# ─── DATABASE (PostgreSQL) ───
DATABASE_URL=postgresql://user:password@localhost:5432/costlens
DB_POOL_MIN=2
DB_POOL_MAX=10

# ─── AUTHENTICATION ───
JWT_SECRET=generate-a-64-char-random-string-here
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ─── ANTHROPIC AI ───
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
ANTHROPIC_MAX_TOKENS=8192

# ─── FILE STORAGE (AWS S3 or compatible) ───
STORAGE_PROVIDER=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET=costlens-uploads
S3_UPLOAD_EXPIRY=3600

# ─── PAYMENTS (Razorpay — for India) ───
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ─── EMAIL (for verification, expert reports, notifications) ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=hello@costlens.in
FROM_NAME=CostLens

# ─── REDIS (for rate limiting, sessions cache) ───
REDIS_URL=redis://localhost:6379

# ─── CORS ───
CORS_ORIGINS=http://localhost:3000,https://costlens.in,https://www.costlens.in

# ─── RATE LIMITING ───
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AI_RATE_LIMIT_PER_MIN=10

# ─── LOGGING ───
LOG_LEVEL=info
